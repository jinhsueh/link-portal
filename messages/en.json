    "faq": {
      "title": "Questions, answered",
      "items": [
        { "q": "Is Beam really free?",                       "a": "Yes. The free plan stays free forever. Upgrade to Pro only when you need unlimited blocks, more pages, or to remove the watermark." },
        { "q": "Can I import from Linktree?",                "a": "Yes. Paste your linktr.ee or portaly.cc URL and Beam pulls your links, socials, name, bio, and avatar in 30 seconds." },
        { "q": "How does selling products work?",            "a": "Connect a Stripe account in settings. Add a product block, set a price, and customers buy directly from your page. Beam takes a small commission depending on plan." },
