# ── Session 簽名密鑰 ──────────────────────────────────────────────────────────
# 產生方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-a-random-64-char-hex-string"

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"

# Production Turso/libSQL database
TURSO_DATABASE_URL="libsql://..."
TURSO_AUTH_TOKEN="..."

# ── Site URLs ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://beam.io"
NEXT_PUBLIC_SITE_HOST="beam.io"

# ── Uploads ──────────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── Stripe 金流設定 ────────────────────────────────────────────────────────────
# 取得方式：https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."

# 前端用（可公開）
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook 簽名密鑰（本機測試用 stripe CLI 產生）
# stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# Pro 訂閱方案 Price ID（在 Stripe Dashboard Products 頁面取得）
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_PRO_ANNUAL_PRICE_ID="price_..."
STRIPE_PREMIUM_PRICE_ID="price_..."
STRIPE_PREMIUM_ANNUAL_PRICE_ID="price_..."
