generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  username  String   @unique
  bio       String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pages       Page[]
  blocks      Block[]
  socialLinks SocialLink[]
  orders      Order[]
  subscribers Subscriber[]
}

model Page {
  id        String   @id @default(cuid())
  userId    String
  name      String
  slug      String
  order     Int      @default(0)
  isDefault Boolean  @default(false)
  theme     String   @default("{}") // JSON: { primaryColor, bgType, bgColor, bgGradient, buttonStyle, fontStyle }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks Block[]

  @@unique([userId, slug])
}

model Block {
  id        String   @id @default(cuid())
  userId    String
  pageId    String
  type      String   // link | banner | video | email_form | product | heading | social
  title     String?
  content   String   @default("{}")  // JSON string
  order     Int      @default(0)
  active    Boolean  @default(true)
  clicks    Int      @default(0)
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  page   Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  orders Order[]
}

model SocialLink {
  id       String @id @default(cuid())
  userId   String
  platform String // instagram | youtube | tiktok | threads | spotify | facebook
  url      String
  order    Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}

model Click {
  id        String   @id @default(cuid())
  blockId   String
  pageId    String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(cuid())
  userId    String
  blockId   String?
  email     String
  source    String   @default("email_form") // email_form | manual
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  blockId         String
  stripeSessionId String   @unique
  customerEmail   String?
  productTitle    String?
  amount          Int      // smallest currency unit (e.g. TWD cents = ×100)
  currency        String   @default("TWD")
  status          String   @default("pending") // pending | paid | failed | refunded
  createdAt       DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  block Block @relation(fields: [blockId], references: [id], onDelete: Cascade)
}
