generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  username     String   @unique
  bio          String?
  avatarUrl    String?
  bannerUrl    String?  // Optional header image displayed at the top of the public profile
  passwordHash String?
  role             String    @default("user")   // "user" | "admin"
  plan             String    @default("free")   // "free" | "pro_trial" | "pro"
  trialEndsAt      DateTime?
  stripeCustomerId String?   @unique
  stripeSubId      String?
  banned           Boolean   @default(false)
  bannedAt         DateTime?
  bannedReason     String?
  notifyNewSubscriber Boolean @default(true)
  notifyNewOrder      Boolean @default(true)
  notifyWeeklyReport  Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pages       Page[]
  blocks      Block[]
  socialLinks SocialLink[]
  orders      Order[]
  subscribers Subscriber[]
  teamMembers TeamMember[]
}

model TeamMember {
  id          String    @id @default(cuid())
  ownerId     String
  memberEmail String
  role        String    @default("viewer") // owner | editor | viewer
  status      String    @default("active") // pending | active
  invitedAt   DateTime  @default(now())
  acceptedAt  DateTime?

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, memberEmail])
}

model Page {
  id        String   @id @default(cuid())
  userId    String
  name      String
  slug      String
  order     Int      @default(0)
  isDefault Boolean  @default(false)
  theme     String   @default("{}") // JSON: { primaryColor, bgType, bgColor, bgGradient, buttonStyle, fontStyle }
  password  String?  // If set, page requires this password to view
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks Block[]

  @@unique([userId, slug])
}

model Block {
  id        String   @id @default(cuid())
  userId    String
  pageId    String
  type      String   // link | banner | video | email_form | product | heading | social
  title     String?
  content   String   @default("{}")  // JSON string
  order     Int      @default(0)
  pinned    Boolean  @default(false) // If true, render before all other blocks (above-the-fold spotlight)
  active        Boolean   @default(true)
  scheduleStart DateTime? // If set, block only visible after this time
  scheduleEnd   DateTime? // If set, block only visible before this time
  clicks        Int       @default(0)
  views         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  page   Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  orders Order[]
}

model SocialLink {
  id       String  @id @default(cuid())
  userId   String
  platform String  // instagram | youtube | tiktok | twitter | threads | facebook | spotify | line | linkedin | pinterest | telegram | whatsapp | custom
  url      String
  label    String?
  iconUrl  String? // Optional uploaded icon — overrides platform's default lucide icon
  order    Int     @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
}

model Click {
  id        String   @id @default(cuid())
  blockId   String
  pageId    String
  ip        String?
  userAgent String?
  referrer  String?
  utmSource String?
  utmMedium String?
  createdAt DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(cuid())
  userId    String
  blockId   String?
  email     String
  source    String   @default("email_form") // email_form | manual
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  blockId         String
  stripeSessionId String   @unique
  customerEmail   String?
  productTitle    String?
  amount          Int      // smallest currency unit (e.g. TWD cents = ×100)
  currency        String   @default("TWD")
  status          String   @default("pending") // pending | paid | failed | refunded
  // Platform commission snapshot at order time (smallest currency unit).
  // Fixed when the order is created so later plan changes don't retroactively
  // alter historical commission accounting.
  commissionRate  Float    @default(0.10) // 0.10 / 0.05 / 0.02
  commissionAmount Int     @default(0)    // = round(amount * commissionRate)
  createdAt       DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  block Block @relation(fields: [blockId], references: [id], onDelete: Cascade)
}
