    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@stripe/stripe-js": "^9.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/qrcode": "^1.5.6",
    "@vercel/blob": "^2.3.2",
    "@vercel/og": "^0.11.1",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.7.0",
    "next": "^16.2.4",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "stripe": "^21.0.1"
