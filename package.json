{
  "name": "link-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && npx tsx scripts/migrate-turso.ts && next build",
    "migrate:turso": "npx tsx scripts/migrate-turso.ts",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "npx tsx prisma/seed.ts",
